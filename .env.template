# NYCWine.com — Environment Variables Template
# ──────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Make a copy of this file and name it exactly:  .env.local
# 2. Fill in each value marked with YOUR_ below
# 3. NEVER share .env.local or commit it to GitHub — it contains secrets
# 4. The integrations-config.js file is the companion to this file (non-secret settings)
#
# Where to create each account / get each key is noted in comments.
# Last updated: March 2026


# ──────────────────────────────────────────────
# GOOGLE GEMINI (AI Concierge — powers the chatbot)
# Free tier: 1,500 requests/day — plenty for a growing site
# Get key at: https://aistudio.google.com → Get API Key (top left)
# Also add this key in: Vercel Dashboard → Project → Settings → Environment Variables
# The concierge shows a friendly fallback message if this key is missing.
# ──────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY


# ──────────────────────────────────────────────
# SUPABASE (your database)
# Create free account at: https://supabase.com
# After creating a project: Settings → API → copy Project URL and anon key
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY


# ──────────────────────────────────────────────
# GOOGLE MAPS + PLACES API
# Enable at: https://console.cloud.google.com
# APIs needed: Maps JavaScript API, Places API
# Free tier: Maps Embed unlimited, Places 10,000 req/month
# ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY


# ──────────────────────────────────────────────
# EVENTBRITE (wine events feed)
# Create free account at: https://www.eventbrite.com/platform/api
# Developer portal → Apps → Create a new app → copy Private Token
# ──────────────────────────────────────────────
EVENTBRITE_API_KEY=YOUR_EVENTBRITE_PRIVATE_TOKEN


# ──────────────────────────────────────────────
# REDDIT API (r/wine and r/nyc posts)
# Register at: https://www.reddit.com/prefs/apps
# Create a "script" type app → copy client ID and secret
# Free tier: 100 requests/minute — plenty for hourly polling
# ──────────────────────────────────────────────
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET


# ──────────────────────────────────────────────
# INSTAGRAM — OUR @nycwine ACCOUNT POSTS
# Instagram Basic Display API or Graph API
# Register app at: https://developers.facebook.com
# Requires: Facebook account + Instagram Business account linked
# This token shows posts FROM @nycwine (your own account)
# ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=YOUR_INSTAGRAM_ACCESS_TOKEN
INSTAGRAM_USER_ID=YOUR_INSTAGRAM_USER_ID


# ──────────────────────────────────────────────
# FACEBOOK PAGE PLUGIN (OUR Facebook page posts)
# Register app at: https://developers.facebook.com → My Apps → Create App
# Free — App ID is technically public but kept here for consistency
# ──────────────────────────────────────────────
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID


# ──────────────────────────────────────────────
# X / TWITTER API  (OPTIONAL — $100/month for hashtag search)
# If skipping paid tier: @nycwine timeline embed is free (no key needed)
# If purchasing Basic API: https://developer.x.com → create app → bearer token
# ──────────────────────────────────────────────
X_API_BEARER_TOKEN=YOUR_X_BEARER_TOKEN_IF_PURCHASED


# ──────────────────────────────────────────────
# ELFSIGHT WIDGETS (Instagram + Pinterest community #nycwine feeds)
# Create account at: https://elfsight.com (~$5/month)
# Widget IDs are also in integrations-config.js but duplicated here for env access
# ──────────────────────────────────────────────
NEXT_PUBLIC_ELFSIGHT_INSTAGRAM_WIDGET_ID=YOUR_ELFSIGHT_IG_WIDGET_ID
NEXT_PUBLIC_ELFSIGHT_PINTEREST_WIDGET_ID=YOUR_ELFSIGHT_PIN_WIDGET_ID


# ──────────────────────────────────────────────
# GOOGLE ADS / AD MANAGER
# ACTION REQUIRED: confirm account type first (see integrations-config.js)
# Publisher ID format: pub-XXXXXXXXXXXXXXXX
# ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_AD_PUBLISHER_ID=YOUR_GOOGLE_AD_PUBLISHER_ID


# ──────────────────────────────────────────────
# MAILCHIMP (email signup)
# Log in at: https://mailchimp.com → Account → Extras → API keys
# ──────────────────────────────────────────────
MAILCHIMP_API_KEY=YOUR_MAILCHIMP_API_KEY
MAILCHIMP_LIST_ID=YOUR_MAILCHIMP_AUDIENCE_LIST_ID
MAILCHIMP_SERVER_PREFIX=YOUR_SERVER_PREFIX
# Server prefix = the part before .api.mailchimp.com in your API endpoint, e.g. "us1"


# ──────────────────────────────────────────────
# YOUTUBE DATA API v3 (NYC Wine Videos sidebar)
# Free, 10,000 units/day. Weekly fetch uses ~100 units.
# Get key at: https://console.cloud.google.com → enable YouTube Data API v3 → Credentials
# Also add this key in: GitHub repo → Settings → Secrets → Actions
# ──────────────────────────────────────────────
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY


# ──────────────────────────────────────────────
# STRIPE  (advertiser self-serve checkout)
# https://dashboard.stripe.com → Developers → API keys
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY

# Webhook signing secret — protects /api/webhooks/stripe from forged requests.
# Get it: Stripe Dashboard → Developers → Webhooks → click your endpoint → "Signing secret".
# When configuring the webhook in Stripe, use:
#   URL:    https://<your-domain>/api/webhooks/stripe
#   Events: checkout.session.completed
#           customer.subscription.deleted   (optional, for cancellations)
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SIGNING_SECRET

# Price IDs — created by running: node scripts/stripe-setup-products.js
# That script outputs all 21 IDs ready to paste below.
STRIPE_PRICE_HEADER_MONTHLY=YOUR_STRIPE_PRICE_HEADER_MONTHLY
STRIPE_PRICE_HEADER_QUARTERLY=YOUR_STRIPE_PRICE_HEADER_QUARTERLY
STRIPE_PRICE_HEADER_ANNUAL=YOUR_STRIPE_PRICE_HEADER_ANNUAL
STRIPE_PRICE_EVENT_MONTHLY=YOUR_STRIPE_PRICE_EVENT_MONTHLY
STRIPE_PRICE_EVENT_QUARTERLY=YOUR_STRIPE_PRICE_EVENT_QUARTERLY
STRIPE_PRICE_EVENT_ANNUAL=YOUR_STRIPE_PRICE_EVENT_ANNUAL
STRIPE_PRICE_BAR_MONTHLY=YOUR_STRIPE_PRICE_BAR_MONTHLY
STRIPE_PRICE_BAR_QUARTERLY=YOUR_STRIPE_PRICE_BAR_QUARTERLY
STRIPE_PRICE_BAR_ANNUAL=YOUR_STRIPE_PRICE_BAR_ANNUAL
STRIPE_PRICE_STORE_MONTHLY=YOUR_STRIPE_PRICE_STORE_MONTHLY
STRIPE_PRICE_STORE_QUARTERLY=YOUR_STRIPE_PRICE_STORE_QUARTERLY
STRIPE_PRICE_STORE_ANNUAL=YOUR_STRIPE_PRICE_STORE_ANNUAL
STRIPE_PRICE_WINERY_MONTHLY=YOUR_STRIPE_PRICE_WINERY_MONTHLY
STRIPE_PRICE_WINERY_QUARTERLY=YOUR_STRIPE_PRICE_WINERY_QUARTERLY
STRIPE_PRICE_WINERY_ANNUAL=YOUR_STRIPE_PRICE_WINERY_ANNUAL
STRIPE_PRICE_SIDEBAR_MONTHLY=YOUR_STRIPE_PRICE_SIDEBAR_MONTHLY
STRIPE_PRICE_SIDEBAR_QUARTERLY=YOUR_STRIPE_PRICE_SIDEBAR_QUARTERLY
STRIPE_PRICE_SIDEBAR_ANNUAL=YOUR_STRIPE_PRICE_SIDEBAR_ANNUAL
STRIPE_PRICE_SOCIAL_MONTHLY=YOUR_STRIPE_PRICE_SOCIAL_MONTHLY
STRIPE_PRICE_SOCIAL_QUARTERLY=YOUR_STRIPE_PRICE_SOCIAL_QUARTERLY
STRIPE_PRICE_SOCIAL_ANNUAL=YOUR_STRIPE_PRICE_SOCIAL_ANNUAL


# ──────────────────────────────────────────────
# PHASE 2 — NOT NEEDED AT LAUNCH
# ──────────────────────────────────────────────
# Wine-Searcher API ($250/month — skip for now)
# WINE_SEARCHER_API_KEY=YOUR_WINE_SEARCHER_API_KEY
